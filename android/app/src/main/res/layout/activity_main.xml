<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F4F6F9">

    <!-- 헤더 -->
    <TextView
        android:text="WITHCALL SMS 자동화"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A73E8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"/>

    <!-- 로드된 단말기 수 -->
    <TextView
        android:id="@+id/tvCount"
        android:text="로드된 단말기: 0대"
        android:textSize="15sp"
        android:textColor="#555"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>

    <!-- 서버 URL -->
    <TextView
        android:text="서버 URL"
        android:textSize="13sp"
        android:textColor="#333"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etServerUrl"
        android:hint="https://withcall.pages.dev"
        android:inputType="textUri"
        android:textSize="13sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <!-- 전송 TEXT 1 -->
    <TextView
        android:text="전송 TEXT 1 (고정 문구)"
        android:textSize="13sp"
        android:textColor="#333"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/etText1"
        android:hint="첫 번째로 전송할 문구 입력"
        android:inputType="text"
        android:textSize="13sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <!-- 버튼 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnLoad"
            android:text="불러오기"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnProcess"
            android:text="업무처리 시작"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false"/>
    </LinearLayout>

    <!-- 진행상황 -->
    <TextView
        android:id="@+id/tvStatus"
        android:text="대기 중..."
        android:textSize="13sp"
        android:textColor="#555"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <!-- 로그 영역 -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="4dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:textColor="#333"/>
    </ScrollView>

</LinearLayout>
