<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingEnd="14dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- ══ 119비상벨 (D열) ════════════════════════════════════════════ -->

    <!-- 번호 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="3dp">
        <TextView
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="119비상벨"
            android:textSize="12sp"
            android:textColor="#1A73E8"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvPhone119"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#1C1B1F"/>
    </LinearLayout>

    <!-- 119 처리 섹션 (전송버튼 + 연락처) : 전송 후 표시 -->
    <LinearLayout
        android:id="@+id/layout119Section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="72dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <!-- 빨간 전송 버튼 + 파란 회신 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/tvSent119"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전송"
                android:textSize="12sp"
                android:textColor="#C62828"
                android:textStyle="bold"
                android:background="@drawable/bg_sent"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReply119"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회신"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                app:cornerRadius="6dp"
                app:backgroundTint="#1A73E8"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- 비상연락처 1~5 동적 추가 -->
        <LinearLayout
            android:id="@+id/containerContacts119"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </LinearLayout>

    <!-- ══ 돌봄비상벨 (F열) ══════════════════════════════════════════ -->

    <!-- 번호 행 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="3dp">
        <TextView
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="돌봄비상벨"
            android:textSize="12sp"
            android:textColor="#5F6368"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/tvPhoneCare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#5F6368"/>
    </LinearLayout>

    <!-- 돌봄 처리 섹션 (전송버튼 + 연락처) : 전송 후 표시 -->
    <LinearLayout
        android:id="@+id/layoutCareSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="72dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone">

        <!-- 빨간 전송 버튼 + 파란 회신 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">
            <TextView
                android:id="@+id/tvSentCare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전송"
                android:textSize="12sp"
                android:textColor="#C62828"
                android:textStyle="bold"
                android:background="@drawable/bg_sent"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReplyCare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회신"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                app:cornerRadius="6dp"
                app:backgroundTint="#1A73E8"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- 비상연락처 1~5 동적 추가 -->
        <LinearLayout
            android:id="@+id/containerContactsCare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="4dp"/>

</LinearLayout>
